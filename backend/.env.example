# Database
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/constructora

# JWT
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING
JWT_EXPIRATION=24h

# AWS
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=YOUR_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET
AWS_S3_BUCKET=constructora-fotos-asistencia-dezai
AWS_REKOGNITION_COLLECTION=dezai-workers

# App
PORT=3000
CORS_ORIGINS=capacitor://localhost,https://api.getziva.com
